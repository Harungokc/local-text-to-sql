# Şirket Sorgu — Ortam Değişkenleri (örnek)
# Kullanım: bu dosyayı .env olarak kopyala ve değerleri doldur, sonra:
#   set -a && source .env && set +a

# --- Veritabanı ---
# Yazma yetkili (demo_veri.py için): tabloları oluşturur/doldurur
DATABASE_URL=postgresql://kullanici:parola@localhost:5432/sirket_demo
# Salt-okunur (uygulama sorguları için). Yoksa DATABASE_URL'e düşer.
# Üretimde mutlaka readonly_user kullan (bkz. KURULUM.md).
SORGU_DATABASE_URL=postgresql://kullanici:parola@localhost:5432/sirket_demo

# --- Yerel Model (OpenAI-uyumlu endpoint) ---
# Faz 1 (M1 8GB + Ollama): 3B kullan. 7B bu makineyi çökertiyor (RAM yetersiz).
YEREL_MODEL=qwen2.5-coder:3b
VLLM_BASE_URL=http://127.0.0.1:11434/v1
YEREL_API_KEY=yerel
# Faz 2 (RunPod + vLLM) — doğru/ağır ölçüm ve final demo için:
# YEREL_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
# (veya 7B'yi sadece GPU'da: qwen2.5-coder:7b)
# VLLM_BASE_URL=http://127.0.0.1:8000/v1

# --- Davranış ayarları (opsiyonel) ---
SORGU_TIMEOUT_MS=8000
SORGU_SATIR_LIMITI=1000
MAKS_DUZELTME=2
CHROMA_YOLU=./chroma_db
